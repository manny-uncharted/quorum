# Sui testnet account that holds gas (SUI) and DUSDC.
# Accepts a bech32 `suiprivkey1...` string (preferred) or a 64-char hex secret key.
# Generate one with:  bunx @mysten/sui keytool generate ed25519   (or the `sui` CLI)
SUI_PRIVATE_KEY=

# Optional overrides (defaults are wired in src/chain/constants.ts).
# SUI_RPC_URL=https://fullnode.testnet.sui.io:443
# PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com

# Reuse this PredictManager across runs once created by the spike (avoids re-creating).
PREDICT_MANAGER_ID=

# Quorum Consensus Oracle — set after `sui client publish move/quorum_oracle`.
# QUORUM_ORACLE_PACKAGE  = the published package id
# QUORUM_ORACLE_OBJECT   = the shared ConsensusOracle object id
# QUORUM_ORACLE_CAP      = the PublisherCap object id (owned by the desk key)
QUORUM_ORACLE_PACKAGE=
QUORUM_ORACLE_OBJECT=
QUORUM_ORACLE_CAP=

